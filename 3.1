# Shot accuracy

shot_accuracy <- events_all %>%
  filter(event_type == "Shot") %>%
  mutate(on_target = if_else(shot_outcome %in% c("Goal", "Saved"), 1, 0)) %>%
  group_by(gender, match_id_std) %>%
  summarise(
    total_shots = n(),
    on_target = sum(on_target),
    accuracy_pct = 100 * on_target / total_shots,
    .groups = "drop"
  )


shot_accuracy_summary <- shot_accuracy %>%
  group_by(gender) %>%
  summarise(
    kampe = n(),
    avg_accuracy = mean(accuracy_pct, na.rm = TRUE),
    .groups = "drop"
  )

shot_accuracy_summary


