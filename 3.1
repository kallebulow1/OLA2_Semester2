# per 100 events

total_events <- events_all %>%
  group_by(gender, match_id_std) %>%
  summarise(total_events = n(), .groups = "drop")

miscontrol_rel <- miscontrol %>%
  left_join(total_events, by = c("gender", "match_id_std")) %>%
  mutate(miscontrol_per_100 = 100 * miscontrols / total_events)

