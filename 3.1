## standiserer

library(dplyr)

f_std <- f_events %>%
  mutate(
    gender = "Kvinder",
    match_id_std = match_id,
    event_type = `type.name`,
    pass_outcome = `pass.outcome.name`,
    shot_outcome = `shot.outcome.name`
  )

m_std <- m_events %>%
  mutate(
    gender = "Mænd",
    match_id_std = matchId,
    event_type = `type.name`,
    pass_outcome = `pass.outcome.name`,
    shot_outcome = `shot.outcome.name`
  )

events_all <- bind_rows(f_std, m_std)

## Shot outcome

events_all %>%
  filter(event_type == "Shot") %>%
  count(shot_outcome, sort = TRUE)

shots_per_match <- events_all %>%
  filter(event_type == "Shot") %>%
  mutate(missed_shot = if_else(shot_outcome == "Goal", 0, 1, missing = 1)) %>%
  group_by(gender, match_id_std) %>%
  summarise(
    total_shots = n(),
    missed_shots = sum(missed_shot, na.rm = TRUE),
    missed_shot_pct = 100 * missed_shots / total_shots,
    .groups = "drop"
  )

head(shots_per_match)




head(passes_per_match)


# Fejl aflveringer

passes_per_match <- events_all %>%
  filter(event_type == "Pass") %>%
  mutate(incomplete_pass = if_else(is.na(pass_outcome), 0, 1)) %>%
  group_by(gender, match_id_std) %>%
  summarise(
    total_passes = n(),
    incomplete_passes = sum(incomplete_pass, na.rm = TRUE),
    incomplete_pass_pct = 100 * incomplete_passes / total_passes,
    .groups = "drop"
  )

head(passes_per_match)


### SUMMARY #####

## Fejl Afleveringer

passes_summary <- passes_per_match %>%
  group_by(gender) %>%
  summarise(
    kampe = n(),
    avg_passes = mean(total_passes, na.rm = TRUE),
    avg_incomplete = mean(incomplete_passes, na.rm = TRUE),
    avg_incomplete_pct = mean(incomplete_pass_pct, na.rm = TRUE),
    .groups = "drop"
  )

passes_summary

# Missede Skud

shots_summary <- shots_per_match %>%
  group_by(gender) %>%
  summarise(
    kampe = n(),
    avg_shots = mean(total_shots, na.rm = TRUE),
    avg_missed = mean(missed_shots, na.rm = TRUE),
    avg_missed_pct = mean(missed_shot_pct, na.rm = TRUE),
    .groups = "drop"
  )

shots_summary


# Samlet

final_summary <- passes_per_match %>%
  inner_join(shots_per_match, by = c("gender", "match_id_std")) %>%
  group_by(gender) %>%
  summarise(
    kampe = n(),
    passes_pr_kamp = mean(total_passes, na.rm = TRUE),
    fejl_pass_pr_kamp = mean(incomplete_passes, na.rm = TRUE),
    fejl_pass_pct = mean(incomplete_pass_pct, na.rm = TRUE),
    skud_pr_kamp = mean(total_shots, na.rm = TRUE),
    missede_skud_pr_kamp = mean(missed_shots, na.rm = TRUE),
    missede_skud_pct = mean(missed_shot_pct, na.rm = TRUE),
    .groups = "drop"
  )

final_summary


## ggplot

ggplot(passes_per_match, aes(x = gender, y = incomplete_pass_pct)) +
  geom_boxplot() +
  labs(title = "Fejlafleveringer (%) pr kamp")



