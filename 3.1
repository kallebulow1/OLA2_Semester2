## ggplot

library(ggplot2)

ggplot(final_summary, aes(x = gender, y = miscontrol_pr_kamp)) +
  geom_col() +
  labs(
    title = "Kvinder mister oftere bolden",
    subtitle = "Gennemsnitlige miscontrols pr. kamp",
    x = "",
    y = "Miscontrols pr. kamp"
  ) +
  theme_minimal()

library(tidyr)

plot_data <- final_summary %>%
  pivot_longer(
    cols = c(miscontrol_pr_kamp, dispossessed_pr_kamp),
    names_to = "metric",
    values_to = "value"
  )

ggplot(plot_data, aes(x = gender, y = value, fill = metric)) +
  geom_col(position = "dodge") +
  labs(
    title = "Flere tekniske fejl i kvindefodbold",
    subtitle = "Sammenligning af miscontrols og boldtab pr. kamp",
    x = "",
    y = "Antal pr. kamp",
    fill = ""
  ) +
  theme_minimal()
